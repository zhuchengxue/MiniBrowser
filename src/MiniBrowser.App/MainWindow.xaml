<Window x:Class="MiniBrowser.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MiniBrowser"
        Width="390"
        Height="844"
        MinWidth="320"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/App.ico"
        Background="#F8F8FA">
    <Window.Resources>
        <Style x:Key="RoundButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#EEF0F4" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#A7AFBA" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E6ED" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D7DDE7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource RoundButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#374151" />
        </Style>

        <Style x:Key="BottomButton" TargetType="Button" BasedOn="{StaticResource RoundButton}">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="CaretBrush" Value="#111827" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="NavRow" Height="58" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="ToolsRow" Height="0" />
            <RowDefinition Height="0" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F8F8FA"
                BorderBrush="#E6E8EE"
                BorderThickness="0,0,0,1"
                Padding="6,9"
                MouseLeftButtonDown="ChromeDragArea_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Height="38"
                        Background="Transparent"
                        CornerRadius="19"
                        Padding="0"
                        Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BackButton"
                                Content="&#xE72B;"
                                Style="{StaticResource IconButton}"
                                ToolTip="Back (Alt+Left)"
                                Click="BackButton_Click" />
                        <Button x:Name="ForwardButton"
                                Content="&#xE72A;"
                                Style="{StaticResource IconButton}"
                                ToolTip="Forward (Alt+Right)"
                                Click="ForwardButton_Click" />
                        <Button x:Name="RefreshButton"
                                Content="&#xE72C;"
                                Style="{StaticResource IconButton}"
                                ToolTip="Reload (F5)"
                                Click="RefreshButton_Click" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Height="40"
                        Background="#ECEFF3"
                        CornerRadius="20"
                        Padding="4,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   FontSize="12"
                                   Foreground="#7B8493" />
                        <TextBox x:Name="AddressBox"
                                 Grid.Column="1"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Search or enter address (Ctrl+L)"
                                 PreviewMouseLeftButtonDown="AddressBox_PreviewMouseLeftButtonDown"
                                 GotKeyboardFocus="AddressBox_GotKeyboardFocus"
                                 MouseDoubleClick="AddressBox_MouseDoubleClick"
                                 KeyDown="AddressBox_KeyDown" />
                    </Grid>
                </Border>

                <Button x:Name="MobileButton"
                        Grid.Column="2"
                        Content="Phone"
                        Width="58"
                        Margin="8,0,0,0"
                        Style="{StaticResource RoundButton}"
                        Visibility="Collapsed"
                        ToolTip="Phone/Desktop mode"
                        Click="MobileButton_Click" />
                <Button x:Name="TopmostButton"
                        Grid.Column="2"
                        Content="&#xE718;"
                        Width="32"
                        Margin="4,0,0,0"
                        Style="{StaticResource IconButton}"
                        Visibility="Collapsed"
                        ToolTip="Keep on top"
                        Click="TopmostButton_Click" />
                <Button x:Name="MenuButton"
                        Grid.Column="2"
                        Content="&#xE700;"
                        Width="34"
                        Margin="5,0,0,0"
                        Style="{StaticResource IconButton}"
                        ToolTip="Menu"
                        Click="MenuButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#EAECF0"
                BorderThickness="0">
            <wv2:WebView2 x:Name="Browser" />
        </Border>

        <ItemsControl x:Name="QuickSites" Visibility="Collapsed" />

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Visibility="Collapsed"
                   Text="Ready" />
    </Grid>
</Window>
